# This is just an example..
# Ignore cache and system files
__pycache__/
 __MACOSX/

# Python
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.egg
*.pyc
*.pyo

# Ignore virtual environments
venv/
env/

# Ignore dataset and output files
data/processed/
*.csv
*.xslx
*.tsv
*.json
*.jsonl
*.log
*.out
*.pt  # PyTorch checkpoint files
*.pkl
data/lexical/*.xml
data/lexical/*.pkl
data/lexical/*.sha256
data/lexical/*.txt

#Ignore swap and temp files
*.un~
*.swp
*tmp

# Ignore system-specific files
.DS_Store
Thumbs.db

# Ignore AI
CLAUDE.md
instructions/
claude_code_prompt_svf_fas_v2.md
# Ignore these sub-directories
dir_1/
.~lock.*#

# Run logs from probe / pipeline / sweep scripts
model_comparison*.txt
pipe-*.txt
modelcomp-*.txt

# SQ3 in-progress rating artifacts (confidential while raters are working).
# These are also caught by the data/processed/ rule above; named explicitly
# so the intent is clear.
data/processed/sq3/sq3_sampled_pairs.csv
data/processed/sq3/sq3_ratings_*.csv

# Test fixtures must be tracked despite the broad *.csv ignore.
!tests/fixtures/
!tests/fixtures/**/*.csv
!tests/fixtures/**/*.xml
